# Supabase (Space Defender leaderboard + daily story facts)
# Create a project at https://supabase.com and run supabase/migrations/*.sql
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# CI / local scripts only — never expose to the browser
# SUPABASE_URL falls back to VITE_SUPABASE_URL in Node scripts when unset
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
